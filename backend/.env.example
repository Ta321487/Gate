# MySQL（工厂元数据库）
GF_DATABASE_URL=mysql+pymysql://gf:gf123456@127.0.0.1:3306/graduate_factory?charset=utf8mb4

# 开发可改用 SQLite：sqlite+aiosqlite:///../data/factory.db
# GF_DATABASE_URL=sqlite+aiosqlite:///../data/factory.db

GF_DATA_DIR=../data
GF_SKELETONS_DIR=../skeletons
GF_HOST=127.0.0.1
GF_PORT=8000
# 服务器部署：GF_HOST=0.0.0.0，GF_PUBLIC_HOST=服务器IP或域名（预览/复制用）
# 学生进程会自动绑 0.0.0.0；也可显式 GF_BIND_HOST=0.0.0.0
GF_PUBLIC_HOST=127.0.0.1
# GF_BIND_HOST=

# DeepSeek：Key 仅环境变量，禁止写入配置文件
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 学生项目端口池
GF_BACKEND_PORT_START=9100
GF_BACKEND_PORT_END=9120
GF_FRONTEND_PORT_START=9200
GF_FRONTEND_PORT_END=9220

# 学生项目 MySQL（与工厂元数据库分离；默认对齐 docker-compose root）
GF_STUDENT_MYSQL_HOST=127.0.0.1
GF_STUDENT_MYSQL_PORT=3306
GF_STUDENT_MYSQL_USER=root
GF_STUDENT_MYSQL_PASSWORD=root123

# Unsplash：Key 仅环境变量（登录氛围图 + 门户轮播检索）；不填则用公开图直链兜底
UNSPLASH_ACCESS_KEY=